# =============================================================================
# Rockchip Linux SDK 根目录 .gitignore
# =============================================================================
# 注意：
# - 不要使用全局 *.bin：rkbin/、部分 tools/ 里包含须跟踪或随 SDK 分发的 .bin。
# - 子树（kernel、u-boot、buildroot 等）另有各自的 .gitignore，此处只处理 SDK 顶层
#   常见的大目录与杂文件。
# =============================================================================

# -----------------------------------------------------------------------------
# repo 工具（.repo/manifests 等元数据体积大；若你只备份源码可忽略）
# -----------------------------------------------------------------------------
.repo/

# -----------------------------------------------------------------------------
# Rockchip build.sh 输出（RK_OUTDIR：固件、log、sessions、security-firmware 等）
# -----------------------------------------------------------------------------
output/

# 通常是指向 output/firmware 的符号链接（无尾部 / 以便匹配 symlink 本身）
/rockdev
rockdev/

# -----------------------------------------------------------------------------
# Buildroot（下载包与产物目录很大）
# -----------------------------------------------------------------------------
buildroot/output/
buildroot/dl/

# -----------------------------------------------------------------------------
# Yocto / BitBake 工作目录
# -----------------------------------------------------------------------------
yocto/build/

# -----------------------------------------------------------------------------
# 可选：工具链/预编译（若希望仓库不含大文件，取消下一行注释并改用单独分发）
# -----------------------------------------------------------------------------
# prebuilts/

# -----------------------------------------------------------------------------
# 编辑器与系统杂项
# -----------------------------------------------------------------------------
*~
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Python（部分脚本与工具）
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
.Python
*.egg-info/
.eggs/

# -----------------------------------------------------------------------------
# 根目录下可能直接生成的零散镜像（主要产物应在 output/ 内）
# -----------------------------------------------------------------------------
/*.img
/*.update

# -----------------------------------------------------------------------------
# 索引/浏览辅助（按需保留时可从本段删除对应行）
# -----------------------------------------------------------------------------
cscope.out
tags
TAGS
GPATH
GRTAGS
GTAGS
external/chromium/
debian/packages/
tools/windows/
tools/linux/PinDebug/
prebuilts/
external/libmali/lib/
external/rknpu2/examples/3rdparty/opencv/
buildroot/archives/
external/camera_engine_rkaiq/**/gen_mesh/android/genMesh_static_32bit/
external/camera_engine_rkaiq/**/gen_mesh/android/genMesh_static_64bit/
